struct Task {
    int id;
    int value;
    Task* next;
    Task* prev;
};

Task* head = nullptr;
Task* tail = nullptr;
map<int, Task*> registry;


void add(int id, int value) {
    if (registry.find(id) != registry.end()) {
        cout << "ID " << id << " уже существует, пропущено" << endl; // ← ДОБАВЛЕНО
        return;
    }

    Task* t = new Task;
    t->id = id;
    t->value = value;
    t->next = nullptr;
    t->prev = tail;

    if (tail != nullptr) {
        tail->next = t;
    }
    else {
        head = t;
    }
    tail = t;
    registry[id] = t;

    cout << "add: id=" << id << " value=" << value << " — добавлено" << endl; // ← ДОБАВЛЕНО
}


void moveFront(int id) {
    if (registry.find(id) == registry.end()) {
        cout << "movetofront: id=" << id << " — не найдено" << endl; // ← ДОБАВЛЕНО
        return;
    }
    Task* t = registry[id];

    if (t == head) {
        cout << "movetofront: id=" << id << " — уже в начале" << endl; // ← ДОБАВЛЕНО
        return;
    }

    if (t->prev != nullptr) t->prev->next = t->next;
    if (t->next != nullptr) t->next->prev = t->prev;
    if (t == tail) tail = t->prev;

    t->prev = nullptr;
    t->next = head;
    if (head != nullptr) head->prev = t;
    head = t;

    cout << "movetofront: id=" << id << " — перемещено в начало" << endl; // ← ДОБАВЛЕНО
}


void getValue(int id) {
    if (registry.find(id) == registry.end()) {
        cout << "getvalue: id=" << id << " — не найдено" << endl; // ← ДОБАВЛЕНО
        return;
    }
    cout << "getvalue: id=" << id << " → значение: " << registry[id]->value << endl; // ← ИЗМЕНЕНО
}


void insertAfter(int targetId, int newId, int value) {
    if (registry.find(targetId) == registry.end()) {
        cout << "insertafter: целевая " << targetId << " не найдена" << endl; // ← ДОБАВЛЕНО
        return;
    }
    if (registry.find(newId) != registry.end()) {
        cout << "insertafter: id=" << newId << " уже существует" << endl; // ← ДОБАВЛЕНО
        return;
    }

    Task* target = registry[targetId];
    Task* t = new Task;
    t->id = newId;
    t->value = value;

    t->next = target->next;
    t->prev = target;
    target->next = t;

    if (t->next != nullptr) {
        t->next->prev = t;
    }
    else {
        tail = t;
    }
    registry[newId] = t;

    cout << "insertafter: id=" << newId << " вставлен после " << targetId << endl; // ← ДОБАВЛЕНО
}


void spliceRange(int idFrom, int idTo) {
    if (registry.find(idFrom) == registry.end() || registry.find(idTo) == registry.end()) {
        cout << "splicerange: одна из задач не найдена" << endl; // ← ДОБАВЛЕНО
        return;
    }

    Task* from = registry[idFrom];
    Task* to = registry[idTo];

    Task* check = from;
    bool valid = false;
    while (check != nullptr) {
        if (check == to) { valid = true; break; }
        check = check->next;
    }
    if (!valid) {
        cout << "splicerange: неверный диапазон" << endl; // ← ДОБАВЛЕНО
        return;
    }

    if (from == head) {
        cout << "splicerange: уже в начале" << endl; // ← ДОБАВЛЕНО
        return;
    }

    Task* beforeFrom = from->prev;
    Task* afterTo = to->next;

    if (beforeFrom != nullptr) beforeFrom->next = afterTo;
    if (afterTo != nullptr) afterTo->prev = beforeFrom;
    if (to == tail) tail = beforeFrom;

    from->prev = nullptr;
    to->next = head;
    if (head != nullptr) head->prev = to;
    head = from;

    cout << "splicerange: диапазон [" << idFrom << "-" << idTo << "] перемещён в начало" << endl; // ← ДОБАВЛЕНО
}


void remove(int id) {
    if (registry.find(id) == registry.end()) {
        cout << "remove: id=" << id << " не найдена" << endl; // ← ДОБАВЛЕНО
        return;
    }

    Task* t = registry[id];

    if (t->prev != nullptr) t->prev->next = t->next;
    else head = t->next;

    if (t->next != nullptr) t->next->prev = t->prev;
    else tail = t->prev;

    registry.erase(id);
    delete t;

    cout << "remove: id=" << id << " — удалено" << endl; // ← ДОБАВЛЕНО
}



void printList(bool debug = false) {
    cout << "\n Итоговый список задач:" << endl;
    if (head == nullptr) {
        cout << "  (список пуст)" << endl;
    }
    else {
        Task* current = head;
        int count = 0;
        while (current != nullptr) {
            if (debug) {
                cout << "  [" << count + 1 << "] id=" << current->id
                    << " val=" << current->value
                    << " prev=" << (current->prev ? to_string(current->prev->id) : "null")
                    << " next=" << (current->next ? to_string(current->next->id) : "null") << endl;
            }
            else {
                cout << "  id: " << current->id << " | Значение: " << current->value << endl;
            }
            current = current->next;
            count++;
        }
        cout << "  Показано задач: " << count << endl;
    }
    cout << "Всего в registry: " << registry.size() << endl;
}

