void writeToFile(const vector<int>& arr, const string& filename, bool append = false, bool showMessage = true) {
    ofstream file(filename, append ? ios::app : ios::out);

    if (file.is_open()) {
        for (size_t i = 0; i < arr.size(); ++i) {
            file << arr[i];
            if (i < arr.size() - 1) {
                file << ", ";
            }
        }
        file << endl;
        file.close();

        if (showMessage) {
            cout << "Файл сохранён: " << filename << endl;
        }
    }
    else {
        cout << "Ошибка создания файла: " << filename << endl;
    }
}

int choice3(vector<int> arr) { //опорный элемент
    int len = arr.size();
    int first = arr[0], mid = arr[len / 2], last = arr[len - 1];

    if ((first > mid) != (first > last))
        return first;
    if ((mid > first) != (mid > last))
        return mid;
    return last;
}

vector<int> readFile() {
    ifstream file("scr.txt");

    if (!file.is_open()) {
        cout << "Ошибка: файл scr.txt не найден!" << endl;
        return {};
    }

    string line;
    getline(file, line);

    for (char& c : line) {
        if (c == '{' || c == '}' || c == ',') {
            c = ' ';
        }
    }

    stringstream ss(line);
    vector<int> vec;
    int num;
    while (ss >> num) {
        vec.push_back(num);
    }

    return vec;
}

vector<int> quicksort(vector<int> arr) {
    if (arr.size() < 2) {
        return arr;
    }
    if (arr.size() == 2) { //сравниваем и меняем местами
        if (arr[0] > arr[1]) {
            int temp_val = arr[0];
            arr[0] = arr[1];
            arr[1] = temp_val;
        }
        return arr;
    }

    vector<int> new_arr = {}, less_op = {}, bigger_op = {};
    int opor = choice3(arr);
    int op_cnt = 0;

    for (int i = 0; i < arr.size(); i++) {
        if (arr[i] < opor) {
            less_op.push_back(arr[i]);
        }
        if (arr[i] > opor) {
            bigger_op.push_back(arr[i]);
        }
        if (arr[i] == opor) {
            op_cnt++;
        }
    }

    less_op = quicksort(less_op); 
    bigger_op = quicksort(bigger_op);

    new_arr = less_op;
    for (int i = 0; i < op_cnt; i++) //соединяем три массива
        new_arr.push_back(opor);
    new_arr.insert(new_arr.end(), bigger_op.begin(), bigger_op.end());
    return new_arr;
}

vector<int> insertsort(vector<int> arr) {
    for (int i = 1; i < arr.size(); i++) {
        int key = arr[i];
        int prev_key = i - 1; //левый элемент
        while (prev_key >= 0 and arr[prev_key] > key) {
            arr[prev_key + 1] = arr[prev_key];
            prev_key--;
        }
        arr[prev_key + 1] = key;
    }
    return arr;
}

vector<int> countsort(vector<int> arr) {
    if (arr.empty()) {//пустой массив не сортируем
        return arr;
    }

    int max_val = 0;
    for (int k = 0; k < arr.size(); k++) {//ищем самое большое число
        if (arr[k] > max_val) {
            max_val = arr[k];
        }
    }

    vector<int> counter(max_val + 1, 0);

    for (int i = 0; i < arr.size(); i++) { //прибавляем к счетчику
        int num = arr[i];          
        counter[num] = counter[num] + 1;  
    }

    vector<int> result;
    for (int chislo = 0; chislo <= max_val; chislo++) { //отсортированный массив
        while (counter[chislo] > 0) {
            result.push_back(chislo);      
            counter[chislo] = counter[chislo] - 1;  
        }
    }

    return result;
}

vector<int> shakersort(vector<int> arr) {
    int left = 0;
    int right = arr.size() - 1;
    bool swapped = true;

    while (left < right&& swapped) {
        swapped = false;

        for (int i = left; i < right; i++) { //слева направо
            if (arr[i] > arr[i + 1]) {
                swap(arr[i], arr[i + 1]);
                swapped = true;
            }
        }
        right--;

        for (int i = right; i > left; i--) { //справа налево
            if (arr[i] < arr[i - 1]) {
                swap(arr[i], arr[i - 1]);
                swapped = true;
            }
        }
        left++;
    }

    return arr;
}

