int comparisons = 0;
int moves = 0;
int runs = 0;


void writeToFile(const vector<int> arr, string filename, bool append = false, bool showMessage = true) {
    ofstream file;
    
    if (append) {
        file.open(filename, ios::app);//если тру открываем для дописывания в конец
    }
    else {
        file.open(filename, ios::out);//если фолс открываем для перезаписи 
    }

    if (file.is_open()) {
        for (size_t i = 0; i < arr.size(); ++i) {
            file << arr[i];
            if (i < arr.size() - 1) {
                file << ", ";
            }
        }
        file << endl;
        file.close();

        if (showMessage) {
            cout << "Файл сохранён: " << filename << endl;
        }
    }
    else {
        cout << "Ошибка создания файла: " << filename << endl;
    }
}


vector<int> readFile() {
    ifstream file("scr.txt");

    if (!file.is_open()) {
        cout << "Ошибка: файл scr.txt не найден!" << endl;
        return {};
    }

    string line;
    getline(file, line);

    for (char& c : line) {
        if (c == '{' || c == '}' || c == ',') {
            c = ' ';
        }
    }

    stringstream ss(line);
    vector<int> vec;
    int num;
    while (ss >> num) {
        vec.push_back(num);
    }

    return vec;
}


vector<int> pryamoe(vector<int> arr) {
    if (arr.size() <= 1) {
        return arr;
    }

    int mid = arr.size() / 2;
    vector<int> left, right; 

    for (int i = 0; i < mid; i++) { //массивы меньше мида
        left.push_back(arr[i]);
        moves++;
    }
    for (int i = mid; i < arr.size(); i++) { //больше мида
        right.push_back(arr[i]);
        moves++;
    }

    left = pryamoe(left); //вызываем для деления пополам
    right = pryamoe(right);//аналогично

    vector<int> result;
    int i = 0, j = 0;

    while (i < left.size() and j < right.size()) { //само сравнение
        comparisons++;
        if (left[i] <= right[j]) {
            result.push_back(left[i]);
            i++;
            moves++;
        }
        else {
            result.push_back(right[j]); //если левый элемент больше правого
            j++;
            moves++;
        }
    }

    while (i < left.size()) {  //скопировать остатки из массива
        result.push_back(left[i]);
        i++;
        moves++;
    }

    while (j < right.size()) { //аналогично
        result.push_back(right[j]);
        j++;
        moves++;
    }

    return result; //возврат отсортированного массива
}

vector<int> estestven(vector<int> arr) {
    if (arr.size() <= 1) {
        return arr;
    }



    vector<vector<int>> serii;      // все найденные серии
    vector<int> tekseriya;          

    tekseriya.push_back(arr[0]);  
    moves++;

    for (int i = 1; i < arr.size(); i++) {
        comparisons++;
        if (arr[i] >= arr[i - 1]) {
            tekseriya.push_back(arr[i]);
            moves++;
        }
        else {
            serii.push_back(tekseriya);
            moves++;
            tekseriya.clear();              // начинаем новую
            tekseriya.push_back(arr[i]);
            moves++;
        }
    }
    serii.push_back(tekseriya);  // не забываем последнюю серию
    moves++;

    runs = serii.size();

    while (serii.size() > 1) { //сливаем пока не останется одна серия
        vector<vector<int>> new_serii;  // новые серии после слияния

        for (int i = 0; i < serii.size(); i += 2) {
            if (i + 1 < serii.size()) {//проверяем есть ли пара для слияния
                vector<int> merged; //соединяем две серии
                int p1 = 0, p2 = 0;
                vector<int> left = serii[i];       
                vector<int> right = serii[i + 1];  

                while (p1 < left.size() and p2 < right.size()) {
                    comparisons++;
                    if (left[p1] <= right[p2]) { //сравниваем элементы
                        merged.push_back(left[p1]);
                        p1++;
                        moves++;
                    }
                    else {
                        merged.push_back(right[p2]);
                        p2++;
                        moves++;
                    }
                }

                while (p1 < left.size()) { //докопируем остатки они уже отсортированы
                    merged.push_back(left[p1]);
                    moves++;
                    p1++;
                }
                while (p2 < right.size()) {
                    merged.push_back(right[p2]);
                    moves++;
                    p2++;
                }

                new_serii.push_back(merged);
                moves++;
            }
            else {
                new_serii.push_back(serii[i]);  // серия без пары просто копируем
                moves++;
            }
        }

        serii = new_serii;
        moves++;
    }

    return serii[0];  
}


void printMetrics(string sortName, double time_ms) {
    cout << sortName << endl;
    cout << "Время выполнения: " << fixed << setprecision(5) << time_ms << " мс" << endl;
    cout << "Количество сравнений: " << comparisons << endl;
    cout << "Количество перемещений: " << moves << endl;
    cout << "Количество серий: " << runs << endl;
    cout << endl;
}

